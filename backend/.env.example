# Copy to .env for local dev. Never commit real secrets.
ENVIRONMENT=local
DEBUG=true

# --- Database (Neon free tier: neon.tech) ---
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/nexus?sslmode=require

# --- Redis (Upstash free tier: console.upstash.com) ---
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# --- Encryption ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

# --- Firebase (free Spark plan: console.firebase.google.com) ---
# Leave AUTH_DEV_BYPASS=true locally to skip real verification
AUTH_DEV_BYPASS=true
FIREBASE_PROJECT_ID=
# Path to downloaded service account JSON, e.g. ./firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=

# --- AI (Google Gemini — free tier: aistudio.google.com) ---
# System-level fallback key used when user hasn't provided their own.
# Free tier: 15 RPM, 1M tokens/day on Gemini 1.5 Flash
GEMINI_API_KEY=

# --- OAuth providers ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: http://localhost:8000/api/integrations/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → Settings → Developer settings → OAuth Apps
# Callback URL: http://localhost:8000/api/integrations/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

CORS_ORIGINS=["http://localhost:5173"]
API_BASE_URL=http://localhost:8000
